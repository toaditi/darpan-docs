{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Darpan",
  "colors": {
    "primary": "#1C1C1C",
    "light": "#F2F2F2",
    "dark": "#5F5F5F"
  },
  "favicon": "/favicon-b17b6c3.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Product docs",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "getting-started/overview",
              "getting-started/core-concepts",
              "getting-started/ask-darpan-navigation",
              "getting-started/environments"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/connect-sftp",
              "guides/connect-netsuite",
              "guides/configure-ai",
              "guides/create-schema",
              "guides/run-reconciliation",
              "guides/review-results"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/file-formats",
              "reference/schema-model",
              "reference/reconciliation-runs",
              "reference/auth-and-access",
              "reference/glossary"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/login-and-session",
              "troubleshooting/file-upload",
              "troubleshooting/connections",
              "troubleshooting/reconciliation-runs"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/json-rpc",
              "api-reference/service-catalog"
            ]
          },
          {
            "group": "Generated reference",
            "openapi": {
              "source": "api-reference/openapi.json",
              "directory": "api-reference/generated"
            }
          }
        ]
      },
      {
        "tab": "Engineering",
        "groups": [
          {
            "group": "Backend engine",
            "pages": [
              "backend/overview",
              "backend/component-layout",
              "backend/service-layer",
              "backend/reconciliation-engine",
              "backend/rules-and-schemas",
              "backend/data-access-and-tenancy",
              "backend/operations-and-validation"
            ]
          },
          {
            "group": "Engineering workflow",
            "pages": [
              "engineering/overview",
              "engineering/process",
              "engineering/repo-map",
              "engineering/ui-page-surface-contracts",
              "engineering/backend-reconciliation-notes",
              "engineering/release-and-linear-workflow"
            ]
          }
        ]
      },
      {
        "tab": "Releases",
        "groups": [
          {
            "group": "Release notes",
            "pages": [
              "releases/updates"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Darpan UI",
          "href": "https://github.com/toaditi/darpan-ui",
          "icon": "github"
        },
        {
          "anchor": "Darpan backend",
          "href": "https://github.com/toaditi/darpan",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light-app-wordmark-v2.svg",
    "dark": "/logo/dark-app-wordmark-v2.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Open Darpan",
      "href": "https://hotwax-darpan-dev.web.app/login"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
