{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Darpan Docs",
  "colors": {
    "primary": "#166534",
    "light": "#0EA5A4",
    "dark": "#86EFAC"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Product docs",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "getting-started/overview",
              "getting-started/core-concepts",
              "getting-started/ask-darpan-navigation",
              "getting-started/environments"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/connect-sftp",
              "guides/connect-netsuite",
              "guides/configure-ai",
              "guides/create-schema",
              "guides/run-reconciliation",
              "guides/review-results"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/file-formats",
              "reference/schema-model",
              "reference/reconciliation-runs",
              "reference/auth-and-access",
              "reference/glossary"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/login-and-session",
              "troubleshooting/file-upload",
              "troubleshooting/connections",
              "troubleshooting/reconciliation-runs"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview",
              "api-reference/json-rpc",
              "api-reference/service-catalog"
            ]
          },
          {
            "group": "Generated reference",
            "openapi": {
              "source": "api-reference/openapi.json",
              "directory": "api-reference/generated"
            }
          }
        ]
      },
      {
        "tab": "Engineering",
        "groups": [
          {
            "group": "Engineering guide",
            "pages": [
              "development",
              "engineering/overview",
              "engineering/local-development",
              "engineering/repo-map",
              "engineering/ui-page-surface-contracts",
              "engineering/backend-reconciliation-notes",
              "engineering/release-and-linear-workflow"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Darpan app",
          "href": "https://toaditi.github.io/darpan-ui/",
          "icon": "monitor"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/toaditi/darpan-docs",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Repository",
        "href": "https://github.com/toaditi/darpan-docs"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Darpan",
      "href": "https://toaditi.github.io/darpan-ui/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/toaditi/darpan-docs"
    }
  }
}
